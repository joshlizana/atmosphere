# Atmosphere compose-stack environment template.
#
# This file is the canonical list of every environment variable the Atmosphere
# docker-compose stack consumes across all milestones. It is committed to the
# repo as a template. Operators copy it to a sibling `.env` (which is
# gitignored) and replace every `CHANGEME` placeholder with a real value for
# their environment. Non-secret defaults are filled in inline; they refer to
# compose service names because every client resolves peers over the compose
# bridge network. Not every key has a live consumer yet — later milestones
# wire services up to keys declared here without reshuffling the surface.

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=CHANGEME
POSTGRES_LAKEKEEPER_USER=lakekeeper
POSTGRES_LAKEKEEPER_PASSWORD=CHANGEME
POSTGRES_PREFECT_USER=prefect
POSTGRES_PREFECT_PASSWORD=CHANGEME
POSTGRES_OPENMETADATA_USER=openmetadata
POSTGRES_OPENMETADATA_PASSWORD=CHANGEME
POSTGRES_GRAFANA_USER=grafana
POSTGRES_GRAFANA_PASSWORD=CHANGEME

# SeaweedFS S3
SEAWEEDFS_S3_ACCESS_KEY=CHANGEME
SEAWEEDFS_S3_SECRET_KEY=CHANGEME
SEAWEEDFS_S3_ENDPOINT=http://seaweedfs:8333
SEAWEEDFS_S3_REGION=us-east-1
SEAWEEDFS_BUCKET_ATMOSPHERE=atmosphere
SEAWEEDFS_BUCKET_FLINK=flink
SEAWEEDFS_BUCKET_LOKI=loki

# Redpanda
REDPANDA_BROKERS=redpanda:9092
REDPANDA_ADMIN_URL=http://redpanda:9644

# Lakekeeper
LAKEKEEPER_URL=http://lakekeeper:8181
LAKEKEEPER_WAREHOUSE=bluesky

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGEME

# Prefect
PREFECT_API_URL=http://prefect-server:4200/api
PREFECT_API_KEY=CHANGEME

# OpenMetadata
OPENMETADATA_ADMIN_EMAIL=admin@atmosphere.local
OPENMETADATA_ADMIN_PASSWORD=CHANGEME
OPENMETADATA_JWT_SECRET=CHANGEME

# ClickHouse
CLICKHOUSE_ADMIN_USER=admin
CLICKHOUSE_ADMIN_PASSWORD=CHANGEME
CLICKHOUSE_QUARTO_USER=quarto
CLICKHOUSE_QUARTO_PASSWORD=CHANGEME
CLICKHOUSE_GRAFANA_USER=grafana
CLICKHOUSE_GRAFANA_PASSWORD=CHANGEME

# Elementary / Quarto gh-pages publisher
GHPAGES_PAT=CHANGEME
GHPAGES_COMMIT_AUTHOR_NAME=atmosphere-bot
GHPAGES_COMMIT_AUTHOR_EMAIL=CHANGEME

# Oracle
ORACLE_DEVICE=cuda
ORACLE_BATCH_SIZE=256
ORACLE_FLUSH_MS=1000
